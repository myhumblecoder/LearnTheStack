generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Month {
  id          Int      @id
  title       String
  description String
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  isBuffer    Boolean  @default(false)
  weeks       Week[]
}

model Week {
  id        Int      @id @default(autoincrement())
  monthId   Int
  weekNum   Int
  title     String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  month     Month    @relation(fields: [monthId], references: [id])
  topics    Topic[]

  @@unique([monthId, weekNum])
}

enum Track {
  CORE
  DSA
  AZURE
  CLAUDE_CODE
}

enum TopicType {
  READ
  BUILD
  EXERCISE
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  QUIZ_PENDING
  COMPLETED
}

model Topic {
  id                 Int            @id @default(autoincrement())
  weekId             Int
  sortOrder          Int
  title              String
  type               TopicType
  track              Track          @default(CORE)
  content            String
  scheduledDate      DateTime?      @db.Date
  estimatedPomodoros Int            @default(2)
  week               Week           @relation(fields: [weekId], references: [id])
  progress           TopicProgress?
  resources          Resource[]
  quizAttempts       QuizAttempt[]
  chatMessages       ChatMessage[]

  @@unique([weekId, sortOrder])
}

enum ResourceType {
  DOC
  VIDEO
  TEXTBOOK
}

model Resource {
  id      Int          @id @default(autoincrement())
  topicId Int
  type    ResourceType
  label   String
  url     String?
  source  String?
  topic   Topic        @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model TopicProgress {
  id          Int            @id @default(autoincrement())
  topicId     Int            @unique
  status      ProgressStatus @default(NOT_STARTED)
  startedAt   DateTime?
  completedAt DateTime?
  topic       Topic          @relation(fields: [topicId], references: [id])
}

model QuizAttempt {
  id        Int      @id @default(autoincrement())
  topicId   Int
  score     Float
  passed    Boolean
  answers   Json
  createdAt DateTime @default(now())
  topic     Topic    @relation(fields: [topicId], references: [id])
}

enum ChatMode {
  LESSON
  QUIZ
  CODE_REVIEW
}

enum FeedbackRating {
  UP
  DOWN
}

model ChatMessage {
  id         Int              @id @default(autoincrement())
  externalId String           @unique @default(dbgenerated("gen_random_uuid()::text"))
  topicId    Int?
  mode       ChatMode
  role       String
  content    String
  createdAt  DateTime         @default(now())
  topic      Topic?           @relation(fields: [topicId], references: [id])
  feedback   MessageFeedback?
}

model MessageFeedback {
  id        Int            @id @default(autoincrement())
  messageId Int            @unique
  rating    FeedbackRating
  reason    String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  message   ChatMessage    @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model StudySession {
  id           Int       @id @default(autoincrement())
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  totalMinutes Int       @default(0)
  pomodoros    Int       @default(0)
  topicId      Int?
}
